# Server A base URL reachable from bdmap1
WORKER_SERVER_BASE_URL=https://your-server-a-host

# Must match WORKER_API_TOKEN on Server A (.env)
WORKER_API_TOKEN=replace_with_strong_shared_token

# Optional worker identity
WORKER_ID=bdmap1-gpu0

# Poll/lease tuning
WORKER_POLL_SECONDS=5
WORKER_LEASE_SECONDS=900

# Inference command mode: choose one option

# Option A: wrapper script mode (preferred)
WORKER_INFER_SCRIPT=/home/visitor/PanTS-Viewer/flask-server/scripts/run_epai_worker.sh

# Option B: command template mode (leave commented unless used)
# WORKER_INFER_CMD_TEMPLATE=source /home/visitor/miniconda3/etc/profile.d/conda.sh && conda activate epai && nnUNetv2_predict_from_modelfolder -i {work_dir} -o {work_dir} -m <model_path> -f all
